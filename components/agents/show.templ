package agents

import (
	"fmt"
	"go-crawler-notification/components/layouts"
	"go-crawler-notification/models"
)

templ Show(props layouts.PageProps, agent models.Agent, events []models.MonitorEvent, running bool, webhooks []models.Webhook) {
	@layouts.Base(props) {
		<div class="page-header">
			<h1>
				<i class="fa fa-robot"></i> { agent.Name }
				<div class="pull-right">
					<a href={ templ.URL(fmt.Sprintf("/agents/%s/edit", agent.ID)) } class="btn btn-default btn-sm">
						<i class="fa fa-pencil"></i> 편집
					</a>
					if running {
						<form method="POST" action={ templ.URL(fmt.Sprintf("/agents/%s/stop", agent.ID)) } style="display:inline;">
							<button type="submit" class="btn btn-warning btn-sm">
								<i class="fa fa-stop"></i> 중지
							</button>
						</form>
					} else {
						<form method="POST" action={ templ.URL(fmt.Sprintf("/agents/%s/start", agent.ID)) } style="display:inline;">
							<button type="submit" class="btn btn-success btn-sm">
								<i class="fa fa-play"></i> 시작
							</button>
						</form>
					}
				</div>
			</h1>
		</div>
		<div class="row">
			<!-- 설정 패널 -->
			<div class="col-md-4">
				<div class="panel panel-default">
					<div class="panel-heading"><strong>설정</strong></div>
					<div class="panel-body">
						<dl class="dl-horizontal" style="margin-bottom:0;">
							<dt>상태</dt>
							<dd>@StatusBadge(running)</dd>
							<dt>URL</dt>
							<dd><a href={ templ.URL(agent.URL) } target="_blank">{ truncate(agent.URL, 50) }</a></dd>
							<dt>키워드</dt>
							<dd>
								if agent.Keyword != "" {
									<code>{ agent.Keyword }</code>
								} else {
									<span class="text-muted">-</span>
								}
							</dd>
							<dt>감지 옵션</dt>
							<dd>@DetectionBadges(agent)</dd>
							<dt>폴링 주기</dt>
							<dd>{ fmt.Sprintf("%d초", agent.IntervalSeconds) }</dd>
							<dt>첫 감지 알림</dt>
							<dd>
								if agent.AlertOnFirstSeen {
									<span class="label label-warning">ON</span>
								} else {
									<span class="label label-default">OFF</span>
								}
							</dd>
						</dl>
					</div>
				</div>
				<!-- 연결된 웹훅 -->
				<div class="panel panel-default">
					<div class="panel-heading">
						<strong>연결된 웹훅</strong>
						<a href="/webhooks/new" class="pull-right btn btn-xs btn-default">+ 추가</a>
					</div>
					<div class="panel-body">
						if len(webhooks) == 0 {
							<p class="text-muted">연결된 웹훅이 없습니다.</p>
						} else {
							<ul class="list-unstyled" style="margin-bottom:0;">
								for _, wh := range webhooks {
									<li>
										<span class={ fmt.Sprintf("label label-%s", webhookKindClass(wh.Kind)) }>{ wh.Kind }</span>
										{ wh.Name }
									</li>
								}
							</ul>
						}
					</div>
				</div>
			</div>
			<!-- 실시간 이벤트 로그 -->
			<div class="col-md-8">
				<div class="panel panel-default">
					<div class="panel-heading">
						<strong><i class="fa fa-list"></i> 실시간 이벤트 로그</strong>
						<span id="sse-status" class="pull-right text-muted small"></span>
					</div>
					<div class="panel-body" style="padding:0;">
						<div id="event-log" class="event-log-container" data-agent-id={ agent.ID }>
							if len(events) == 0 {
								<div id="no-events-msg" class="text-center text-muted" style="padding:20px;">
									<i class="fa fa-clock"></i> 이벤트 대기 중...
								</div>
							}
							for _, ev := range events {
								@EventLogRow(ev)
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	}
}

templ EventLogRow(ev models.MonitorEvent) {
	<div class={ fmt.Sprintf("event-row event-row-%s", ev.Status) }>
		<span class="event-time">{ ev.OccurredAt.Format("15:04:05") }</span>
		@eventStatusIcon(ev.Status)
		<span class="event-message">{ ev.Message }</span>
		if ev.Mode != "" {
			<span class="label label-default event-mode">{ ev.Mode }</span>
		}
	</div>
}

templ eventStatusIcon(status string) {
	switch status {
	case "matched":
		<i class="fa fa-magnifying-glass text-warning"></i>
	case "version_changed":
		<i class="fa fa-arrow-up text-primary"></i>
	case "error":
		<i class="fa fa-exclamation-triangle text-danger"></i>
	default:
		<i class="fa fa-check text-muted"></i>
	}
}

func webhookKindClass(kind string) string {
	switch kind {
	case "slack":
		return "success"
	case "telegram":
		return "info"
	default:
		return "default"
	}
}
