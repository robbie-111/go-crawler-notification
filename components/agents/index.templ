package agents

import (
	"fmt"
	"go-crawler-notification/components/layouts"
	"go-crawler-notification/models"
)

templ Index(props layouts.PageProps, agents []models.Agent, runningIDs map[string]bool) {
	@layouts.Base(props) {
		<div class="page-header">
			<h1>
				<i class="fa fa-robot"></i> Agents
				<a href="/agents/new" class="btn btn-primary btn-sm pull-right">
					<i class="fa fa-plus"></i> New Agent
				</a>
			</h1>
		</div>
		if len(agents) == 0 {
			<div class="alert alert-info">
				<i class="fa fa-info-circle"></i>
				등록된 에이전트가 없습니다.
				<a href="/agents/new">새 에이전트를 만들어 보세요.</a>
			</div>
		} else {
			<div class="table-responsive">
				<table class="table table-striped table-hover">
					<thead>
						<tr>
							<th>이름</th>
							<th>URL</th>
							<th>키워드</th>
							<th>감지 옵션</th>
							<th>주기</th>
							<th>웹훅</th>
							<th>상태</th>
							<th>액션</th>
						</tr>
					</thead>
					<tbody>
						for _, agent := range agents {
							@AgentRow(agent, runningIDs[agent.ID])
						}
					</tbody>
				</table>
			</div>
		}
	}
}

templ AgentRow(agent models.Agent, running bool) {
	<tr>
		<td>
			<a href={ templ.URL(fmt.Sprintf("/agents/%s", agent.ID)) }>
				<strong>{ agent.Name }</strong>
			</a>
		</td>
		<td>
			<small class="text-muted" title={ agent.URL }>
				{ truncate(agent.URL, 40) }
			</small>
		</td>
		<td>
			if agent.Keyword != "" {
				<code>{ agent.Keyword }</code>
			} else {
				<span class="text-muted">-</span>
			}
		</td>
		<td>
			@DetectionBadges(agent)
		</td>
		<td>
			<small>{ fmt.Sprintf("%ds", agent.IntervalSeconds) }</small>
		</td>
		<td>
			<small class="text-muted">{ fmt.Sprintf("%d개", len(agent.WebhookIDs)) }</small>
		</td>
		<td>
			@StatusBadge(running)
		</td>
		<td>
			<div class="btn-group btn-group-xs">
				<a href={ templ.URL(fmt.Sprintf("/agents/%s", agent.ID)) } class="btn btn-default" title="상세">
					<i class="fa fa-eye"></i>
				</a>
				<a href={ templ.URL(fmt.Sprintf("/agents/%s/edit", agent.ID)) } class="btn btn-default" title="편집">
					<i class="fa fa-pencil"></i>
				</a>
				if running {
					<form method="POST" action={ templ.URL(fmt.Sprintf("/agents/%s/stop", agent.ID)) } style="display:inline;">
						<button type="submit" class="btn btn-warning" title="중지">
							<i class="fa fa-stop"></i>
						</button>
					</form>
				} else {
					<form method="POST" action={ templ.URL(fmt.Sprintf("/agents/%s/start", agent.ID)) } style="display:inline;">
						<button type="submit" class="btn btn-success" title="시작">
							<i class="fa fa-play"></i>
						</button>
					</form>
				}
				<form method="POST" action={ templ.URL(fmt.Sprintf("/agents/%s/delete", agent.ID)) } style="display:inline;" onsubmit="return confirm('정말 삭제하시겠습니까?')">
					<button type="submit" class="btn btn-danger" title="삭제">
						<i class="fa fa-trash"></i>
					</button>
				</form>
			</div>
		</td>
	</tr>
}

templ DetectionBadges(agent models.Agent) {
	if agent.EnableKeyword {
		<span class="label label-info">키워드</span>
	}
	if agent.EnableVersion {
		<span class="label label-primary">버전</span>
	}
}

templ StatusBadge(running bool) {
	if running {
		<span class="label label-success"><i class="fa fa-circle"></i> 실행 중</span>
	} else {
		<span class="label label-default"><i class="fa fa-circle"></i> 중지</span>
	}
}

func truncate(s string, n int) string {
	if len(s) <= n {
		return s
	}
	return s[:n] + "..."
}
